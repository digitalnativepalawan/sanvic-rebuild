# Supabase (optional for content, required for login/profile/Pulse chat —
# the app runs on bundled local data when these are absent, but sign-in and
# the Live Feed need a real project).
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Admin passkey for /admin (prototype-grade gate; ships in the client bundle).
# Dev fallback when unset: 5309. Production builds with no passkey keep /admin locked.
# Before real production use, move admin behind Supabase Auth — see README.
VITE_ADMIN_PASSKEY=

# Never put a service-role key in this file or anywhere in the frontend.
